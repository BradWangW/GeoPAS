   "source": [
    "# Read relert_bbob and construct log_relert_bbob\n",
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"data/relert_bbob.csv\")\n",
    "\n",
    "# Apply log to df[:, 2:] and store in new dataframe\n",
    "import numpy as np\n",
    "df.iloc[:, 2:] = np.log(df.iloc[:, 2:])\n",
    "df.to_csv(\"data/log_relert_bbob.csv\", index=False)"
   ]
